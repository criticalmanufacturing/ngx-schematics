{
  "name": "@criticalmanufacturing/schematics",
  "version": "12.0.0-alpha.1",
  "description": "Critical Manufacturing Angular Schematics",
  "private": true,
  "dependencies": {
    "@angular-devkit/core": "^22.0.1",
    "@angular-devkit/schematics": "^22.0.1",
    "@angular-eslint/schematics": "^22.0.0",
    "@angular/localize": "^22.0.1",
    "@angular/pwa": "^22.0.1",
    "@inquirer/prompts": "^8.5.2",
    "@schematics/angular": "^22.0.1",
    "node-html-parser": "^7.1.0",
    "ora": "^9.4.0",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@angular-devkit/schematics-cli": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "angular-eslint": "^22.0.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.4.1",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
